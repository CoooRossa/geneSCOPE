% Generated by hand for Task71
\name{scoreExternalReferenceSTRING}
\alias{scoreExternalReferenceSTRING}
\title{Score STRING external reference and store results}
\usage{
scoreExternalReferenceSTRING(
  x,
  grid_name = "grid30",
  stats_layer = "LeeStats_Xz",
  graph_slot = "g_consensus",
  edge_weight = "weight",
  species = 9606,
  input_id_type = "gene",
  string_score_threshold = 700,
  precision_k = c(50L, 100L, 500L),
  top_frac = 0.01,
  null_method = c("degree_preserving", "label_permutation"),
  run_null = FALSE,
  n_null = 50L,
  null_seed = 1,
  cache_dir = NULL,
  keep_details = FALSE,
  keep_subscores = TRUE,
  verbose = getOption("geneSCOPE.verbose", TRUE),
  ...
)
}
\arguments{
\item{x}{A \code{scope_object}, an \code{igraph}, or a list returned by \code{plotDendroNetwork()}.}
\item{grid_name}{Grid layer name for \code{scope_object} input.}
\item{stats_layer}{Stats layer name for \code{scope_object} input.}
\item{graph_slot}{Graph slot name for \code{scope_object} input.}
\item{edge_weight}{Edge attribute used for ranking edges.}
\item{species}{NCBI taxonomy ID for STRING.}
\item{input_id_type}{Input ID type for STRINGdb mapping (default \code{"gene"}).}
\item{string_score_threshold}{STRING combined score threshold for positives.}
\item{precision_k}{Vector of K values for precision@K.}
\item{top_frac}{Fraction of top edges for enrichment evaluation.}
\item{null_method}{Null strategy (\code{"degree_preserving"} or \code{"label_permutation"}).}
\item{run_null}{Whether to run null evaluation.}
\item{n_null}{Number of null rewires.}
\item{null_seed}{Random seed for null evaluation.}
\item{cache_dir}{Optional directory for caching STRING mappings/interactions.}
\item{keep_details}{Whether to retain edge-level annotations in the output.}
\item{keep_subscores}{Whether to append STRING evidence subscores (nscore..tscore) into the stored edge table.}
\item{verbose}{Emit progress messages when TRUE.}
\item{...}{Reserved for future extensions.}
}
\value{
If \code{x} is a \code{scope_object}, returns the updated \code{scope_object} with
STRING evaluation stored under \code{scope_obj@stats[[grid_name]][[stats_layer]]$external_reference$STRINGdb}.
If \code{x} is an \code{igraph} or list, returns the scoring payload list.
}
\description{
Scores graph edges against STRING and stores the results in a structured payload
(meta, mapping, scores, enrichment, curves, notes_rebuttal) without modifying existing stats fields.
}
\details{
If STRINGdb is not installed or \code{GENESCOPE_DISABLE_STRINGDB=1}, the function
throws a deterministic error with installation guidance.
}
\examples{
\dontrun{
scope_obj <- scoreExternalReferenceSTRING(scope_obj, grid_name = "grid30")
}
}
