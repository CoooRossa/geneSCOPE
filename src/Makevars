CXX_STD = CXX17

# Fix06: Portable OpenMP detection for CRAN compliance
# Avoids -fopenmp hardcoding that causes warnings on clang/Intel compilers

PKG_CPPFLAGS = -DARMA_64BIT_WORD=1 -DARMA_NO_DEBUG=1 \
    -DOPENBLAS_NUM_THREADS=1 -DMKL_NUM_THREADS=1 \
    -DARMA_USE_LAPACK -DARMA_USE_BLAS -DNDEBUG \
    $(PKG_CPPFLAGS_EXTRA)

# Use SHLIB_OPENMP_CXXFLAGS from R config (handles clang -fopenmp eligibility)
# R 4.0+ automatically sets these based on $(R_HOME)/etc/Makeconf
# Note: For C++ code, use SHLIB_OPENMP_CXXFLAGS not SHLIB_OPENMP_CFLAGS
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS) $(PKG_CXXFLAGS_EXTRA)
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) $(PKG_LIBS_EXTRA)

# Note: On macOS with clang, SHLIB_OPENMP_CFLAGS is typically empty,
# which disables OpenMP gracefully. Users needing OpenMP should install
# libomp via Homebrew and set environment variables accordingly.
